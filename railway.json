{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install",
    "nixPkgs": ["nodejs_18"]
  },
  "deploy": {
    "startCommand": "cd server && node server.js",
    "healthcheckPath": "/api/productslimit",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}
